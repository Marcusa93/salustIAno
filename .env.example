# Variables de entorno de Salu
# Copiá este archivo como .env.local y completá los valores reales.
# .env.local NO se commitea (está en .gitignore).

# ----------------------------------------------------------------------
# Supabase (paso 2)
# ----------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------
# OpenRouter (paso 6, capa de IA)
# ----------------------------------------------------------------------
# OPENROUTER_API_KEY=
# OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# ----------------------------------------------------------------------
# App
# ----------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=http://localhost:3000
