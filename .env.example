# Variables de entorno de Salu.
# Copiá este archivo como .env.local y completá los valores reales.
# .env.local NO se commitea (está en .gitignore).

# ----------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------
# Dashboard → Settings → API:
#   - Project URL → NEXT_PUBLIC_SUPABASE_URL
#   - Publishable key (anon legacy también sirve) → NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# Dashboard → Settings → API → Service role / Secret keys:
#   - Secret key (NUNCA exponer al cliente) → SUPABASE_SECRET_KEY
NEXT_PUBLIC_SUPABASE_URL=https://nszwkhwqfezcrvvqskdb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ----------------------------------------------------------------------
# OpenRouter (paso 6, capa de IA)
# ----------------------------------------------------------------------
# https://openrouter.ai/settings/keys → API key → OPENROUTER_API_KEY
# Modelo por defecto si una tarea no especifica uno:
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# ----------------------------------------------------------------------
# App
# ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------
# Web Push (notificaciones)
# ----------------------------------------------------------------------
# Generar las keys con: `npx web-push generate-vapid-keys`
# Si están vacías, /perfil muestra "no disponible" sin crashear.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=marco.rossi@derecho.unt.edu.ar

# ----------------------------------------------------------------------
# Alexa Skill (integración por voz — endpoint /api/alexa)
# ----------------------------------------------------------------------
# applicationId de la Skill (Alexa Developer Console → tu Skill → Endpoint).
# Con esto seteado, /api/alexa rechaza requests de otras skills.
ALEXA_SKILL_ID=
